{
  # Global options
  acme_ca https://acme-v02.api.letsencrypt.org/directory
  email {$LETSENCRYPT_EMAIL}
  import /etc/caddy/addons/*.conf
}

# N8N
{$N8N_HOSTNAME} {
  reverse_proxy n8n:5678
}

# Supabase (via Kong API gateway)
{$SUPABASE_HOSTNAME} {
  reverse_proxy kong:8000
}

# Neo4j Browser
{$NEO4J_HOSTNAME} {
  reverse_proxy neo4j:7474
}

# Disabled services:
# Ollama API — access via internal Docker network only
# SearXNG — access via internal Docker network only
