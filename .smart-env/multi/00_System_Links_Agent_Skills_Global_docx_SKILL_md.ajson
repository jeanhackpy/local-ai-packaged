lysis#Editing Existing Documents#Common Pitfalls#{2}":[452,453],"#DOCX creation, editing, and analysis#Editing Existing Documents#Common Pitfalls#{3}":[454,455],"#DOCX creation, editing, and analysis#XML Reference":[456,584],"#DOCX creation, editing, and analysis#XML Reference#Schema Compliance":[458,463],"#DOCX creation, editing, and analysis#XML Reference#Schema Compliance#{1}":[460,460],"#DOCX creation, editing, and analysis#XML Reference#Schema Compliance#{2}":[461,461],"#DOCX creation, editing, and analysis#XML Reference#Schema Compliance#{3}":[462,463],"#DOCX creation, editing, and analysis#XML Reference#Tracked Changes":[464,529],"#DOCX creation, editing, and analysis#XML Reference#Tracked Changes#{1}":[466,529],"#DOCX creation, editing, and analysis#XML Reference#Comments":[530,555],"#DOCX creation, editing, and analysis#XML Reference#Comments#{1}":[532,555],"#DOCX creation, editing, and analysis#XML Reference#Images":[556,584],"#DOCX creation, editing, and analysis#XML Reference#Images#{1}":[558,558],"#DOCX creation, editing, and analysis#XML Reference#Images#{2}":[559,562],"#DOCX creation, editing, and analysis#XML Reference#Images#{3}":[560,562],"#DOCX creation, editing, and analysis#XML Reference#Images#{4}":[563,566],"#DOCX creation, editing, and analysis#XML Reference#Images#{5}":[564,566],"#DOCX creation, editing, and analysis#XML Reference#Images#{6}":[567,584],"#DOCX creation, editing, and analysis#XML Reference#Images#{7}":[568,584],"#DOCX creation, editing, and analysis#Dependencies":[585,591],"#DOCX creation, editing, and analysis#Dependencies#{1}":[587,587],"#DOCX creation, editing, and analysis#Dependencies#{2}":[588,588],"#DOCX creation, editing, and analysis#Dependencies#{3}":[589,589],"#DOCX creation, editing, and analysis#Dependencies#{4}":[590,591]},"outlinks":[],"metadata":{"name":"docx","description":"Use this skill whenever the user wants to create, read, edit, or manipulate Word documents (.docx files). Triggers include: any mention of 'Word doc', 'word document', '.docx', or requests to produce professional documents with formatting like tables of contents, headings, page numbers, or letterheads. Also use when extracting or reorganizing content from .docx files, inserting or replacing images in documents, performing find-and-replace in Word files, working with tracked changes or comments, or converting content into a polished Word document. If the user asks for a 'report', 'memo', 'letter', 'template', or similar deliverable as a Word or .docx file, use this skill. Do NOT use for PDFs, spreadsheets, Google Docs, or general coding tasks unrelated to document generation.","license":"Proprietary. LICENSE.txt has complete terms"},"task_lines":[],"tasks":{},"codeblock_ranges":[[25,27],[31,37],[41,44],[50,52],[61,72],[76,78],[82,97],[107,114],[120,140],[144,174],[180,203],[209,214],[225,235],[239,245],[249,268],[272,289],[293,317],[321,348],[354,357],[361,376],[403,405],[417,420],[429,433],[437,439],[467,471],[474,478],[483,493],[496,508],[512,518],[521,528],[536,554],[560,562],[564,566],[568,581]],"key":"00_System/Links/Agent_Skills_Global/docx/SKILL.md"},
