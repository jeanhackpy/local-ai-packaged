t the local AI services#{1}":[2404,2413],"#Change the name of this file to .env after updating it!":[2414,2416],"#Change the name of this file to .env after updating it!###########":[2416,2416],"#[required]":[2417,2417],"#n8n credentials - use the command `openssl rand -hex 32` to generate both":[2418,2418],"#openssl is available by default on Linux/Mac":[2419,2419],"#For Windows, you can use the 'Git Bash' terminal installed with git":[2420,2420],"#Or run the command: python -c \"import secrets; print(secrets.token_hex(32))\"":[2421,2428],"#Or run the command: python -c \"import secrets; print(secrets.token_hex(32))\"###########":[2422,2427],"#Or run the command: python -c \"import secrets; print(secrets.token_hex(32))\"############{1}":[2424,2427],"#Or run the command: python -c \"import secrets; print(secrets.token_hex(32))\"############{2}":[2428,2428],"#[required][2]":[2429,2429],"#Supabase Secrets":[2430,2431],"#YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION":[2432,2432],"#Read these docs for any help: https://supabase.com/docs/guides/self-hosting/docker":[2433,2433],"#For the JWT Secret and keys, see: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys":[2434,2434],"#For the other secrets, see: https://supabase.com/docs/guides/self-hosting/docker#update-secrets":[2435,2435],"#You can really decide any value for POOLER_TENANT_ID like 1000.":[2436,2437],"#Note that using special symbols (like '%') can complicate things a bit for your Postgres password.":[2438,2438],"#If you use special symbols in your Postgres password, you must remember to percent-encode your password later if using the Postgres connection string, for example, postgresql://postgres.projectref:p%3Dword@aws-0-us-east-1.pooler.supabase.com:6543/postgres":[2439,2450],"#If you use special symbols in your Postgres password, you must remember to percent-encode your password later if using the Postgres connection string, for example, postgresql://postgres.projectref:p%3Dword@aws-0-us-east-1.pooler.supabase.com:6543/postgres###########":[2440,2449],"#If you use special symbols in your Postgres password, you must remember to percent-encode your password later if using the Postgres connection string, for example, postgresql://postgres.projectref:p%3Dword@aws-0-us-east-1.pooler.supabase.com:6543/postgres############{1}":[2442,2449],"#If you use special symbols in your Postgres password, you must remember to percent-encode your password later if using the Postgres connection string, for example, postgresql://postgres.projectref:p%3Dword@aws-0-us-east-1.pooler.supabase.com:6543/postgres############{2}":[2450,2450],"#[required][3]":[2451,2451],"#Neo4j username and password":[2452,2452],"#Replace \"neo4j\" with your chosen username and \"password\" with your chosen password.":[2453,2453],"#Keep the \"/\" as a separator between the two.":[2454,2459],"#Keep the \"/\" as a separator between the two.###########":[2455,2458],"#Keep the \"/\" as a separator between the two.############{1}":[2457,2458],"#Keep the \"/\" as a separator between the two.############{2}":[2459,2459],"#[required][4]":[2460,2460],"#Langfuse credentials":[2461,2461],"#Each of the secret keys you can set to whatever you want, just make it secure!":[2462,2462],"#For the encryption key, use the command `openssl rand -hex 32`":[2463,2463],"#openssl is available by defualt on Linux/Mac":[2464,2464],"#For Windows, you can use the 'Git Bash' terminal installed with git[2]":[2465,2474],"#For Windows, you can use the 'Git Bash' terminal installed with git[2]###########":[2466,2473],"#For Windows, you can use the 'Git Bash' terminal installed with git[2]############{1}":[2468,2473],"#For Windows, you can use the 'Git Bash' terminal installed with git[2]############{2}":[2474,2474],"#[required for prod]":[2475,2475],"#Caddy Config":[2476,2477],"#By default listen on https://localhost:[service port] and don't use an email for SSL":[2478,2478],"#To change this for production:":[2479,2479],"#