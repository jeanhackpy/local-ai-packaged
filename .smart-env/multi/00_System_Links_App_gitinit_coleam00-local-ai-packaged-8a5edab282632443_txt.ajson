al SearXNG Config":[2517,2517],"#If you run a very small or a very large instance, you might want to change the amount of used uwsgi workers and threads per worker":[2518,2518],"#More workers (= processes) means that more search requests can be handled at the same time, but it also causes more resource usage":[2519,2521],"#More workers (= processes) means that more search requests can be handled at the same time, but it also causes more resource usage###########":[2520,2521],"#SEARXNG_UWSGI_WORKERS=4":[2522,2522],"#SEARXNG_UWSGI_THREADS=4":[2523,2525],"#SEARXNG_UWSGI_THREADS=4###########":[2525,2525],"#Database - You can change these to any PostgreSQL database that has logical replication enabled.":[2526,2531],"#Database - You can change these to any PostgreSQL database that has logical replication enabled.###########":[2527,2531],"#Database - You can change these to any PostgreSQL database that has logical replication enabled.############{1}":[2529,2531],"#default user is postgres":[2532,2535],"#default user is postgres#{1}":[2533,2534],"#default user is postgres###########":[2535,2535],"#Supavisor -- Database pooler and others that can be left as default values":[2536,2542],"#Supavisor -- Database pooler and others that can be left as default values###########":[2537,2542],"#Supavisor -- Database pooler and others that can be left as default values############{1}":[2538,2542],"#Pool size for internal metadata storage used by Supavisor":[2543,2543],"#This is separate from client connections and used only by Supavisor itself":[2544,2548],"#This is separate from client connections and used only by Supavisor itself#{1}":[2545,2547],"#This is separate from client connections and used only by Supavisor itself###########":[2548,2548],"#API Proxy - Configuration for the Kong Reverse proxy.":[2549,2556],"#API Proxy - Configuration for the Kong Reverse proxy.###########":[2550,2555],"#API Proxy - Configuration for the Kong Reverse proxy.############{1}":[2552,2555],"#API Pr