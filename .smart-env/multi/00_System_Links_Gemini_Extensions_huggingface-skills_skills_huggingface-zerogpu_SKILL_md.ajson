02,202],"#Hugging Face ZeroGPU#Concurrency#{4}":[203,204],"#Hugging Face ZeroGPU#Call Granularity":[205,230],"#Hugging Face ZeroGPU#Call Granularity#{1}":[207,230],"#Hugging Face ZeroGPU#CUDA Build Constraints":[231,240],"#Hugging Face ZeroGPU#CUDA Build Constraints#{1}":[233,240],"#Hugging Face ZeroGPU#Example Caching":[241,257],"#Hugging Face ZeroGPU#Example Caching#{1}":[243,244],"#Hugging Face ZeroGPU#Example Caching#{2}":[245,245],"#Hugging Face ZeroGPU#Example Caching#{3}":[246,247],"#Hugging Face ZeroGPU#Example Caching#{4}":[248,257],"#Hugging Face ZeroGPU#Dependency Management":[258,290],"#Hugging Face ZeroGPU#Dependency Management#`python_version` pin in README frontmatter":[260,270],"#Hugging Face ZeroGPU#Dependency Management#`python_version` pin in README frontmatter#{1}":[262,270],"#Hugging Face ZeroGPU#Dependency Management#Do not pin `spaces` in `requirements.txt`":[271,286],"#Hugging Face ZeroGPU#Dependency Management#Do not pin `spaces` in `requirements.txt`#{1}":[273,278],"#Hugging Face ZeroGPU#Dependency Management#Do not pin `spaces` in `requirements.txt`#{2}":[279,279],"#Hugging Face ZeroGPU#Dependency Management#Do not pin `spaces` in `requirements.txt`#{3}":[280,284],"#Hugging Face ZeroGPU#Dependency Management#Do not pin `spaces` in `requirements.txt`#{4}":[281,284],"#Hugging Face ZeroGPU#Dependency Management#Do not pin `spaces` in `requirements.txt`#{5}":[285,286],"#Hugging Face ZeroGPU#Dependency Management#Pin `torch` to match wheel tags":[287,290],"#Hugging Face ZeroGPU#Dependency Management#Pin `torch` to match wheel tags#{1}":[289,290]},"outlinks":[{"title":"ZeroGPU docs","target":"https://huggingface.co/docs/hub/spaces-zerogpu","line":34},{"title":"ahead-of-time compilation (AoTI)","target":"https://huggingface.co/blog/zerogpu-aoti","line":55},{"title":"ZeroGPU docs","target":"https://huggingface.co/docs/hub/spaces-zerogpu","line":146},{"title":"ZeroGPU docs","target":"https://huggingface.co/docs/hub/spaces-zerogpu","line":262}],"metadata":{"name":"huggingface-zerogpu","description":"AI demos and GPU compute with Gradio Spaces and Hugging Face Spaces ZeroGPU. Use when writing or reviewing code that uses `@spaces.GPU`, configuring `python_version` or `requirements.txt` for a ZeroGPU Space, or handling ZeroGPU-specific code constraints — pickle-based process isolation, `gr.State` semantics across the worker boundary, no `torch.compile` (use AoTI instead), CUDA wheel-only builds (no `nvcc` at build or runtime), large vs xlarge sizing, and dynamic duration callables. Make sure to use this skill whenever the user mentions ZeroGPU, `@spaces.GPU`, or the `spaces` Python package, or hits ZeroGPU-specific code errors like `PicklingError` across the worker boundary, `illegal duration`, or `flash-attn` wheel-build failures — even when the user does not explicitly ask for ZeroGPU coding guidance. Trigger on `import spaces` or `@spaces.GPU` in code."},"task_lines":[],"tasks":{},"codeblock_ranges":[[38,48],[58,62],[87,90],[114,122],[134,140],[158,165],[211,227],[254,256],[264,267],[281,283]],"key":"00_System/Links/Gemini_Extensions/huggingface-skills/skills/huggingface-zerogpu/SKILL.md"},
