login\")":[216,216],"#e.g., await page.fill(\"input[name='username']\", \"testuser\")":[217,217],"#e.g., await page.fill(\"input[name='password']\", \"password123\")":[218,218],"#e.g., await page.click(\"button[type='submit']\")":[219,219],"#e.g., await page.wait\\_for\\_selector(\"#welcome\")":[220,220],"#e.g., await context.add\\_cookies([...])":[221,221],"#Then continue":[222,222],"#Example 3: Adjust the viewport":[223,257],"#Example 3: Adjust the viewport#{1}":[224,257],"#Called before navigating to each URL.":[258,267],"#Called before navigating to each URL.#{1}":[259,267],"#e.g., inject custom headers":[268,300],"#e.g., inject custom headers#{1}":[269,300],"#Called after navigation completes.":[301,310],"#Called after navigation completes.#{1}":[302,310],"#e.g., wait for a certain element if we want to verify":[311,355],"#e.g., wait for a certain element if we want to verify#{1}":[312,355],"#Called whenever the user agent updates.":[356,382],"#Called whenever the user agent updates.#{1}":[357,382],"#Called after custom JavaScript execution begins.":[383,404],"#Called after custom JavaScript execution begins.#{1}":[384,404],"#Called before final HTML retrieval.":[405,409],"#Called before final HTML retrieval.#{1}":[406,409],"#Example: Scroll again":[410,438],"#Example: Scroll again#{1}":[411,438],"#Called just before returning the HTML in the result.":[439,454],"#Called just before returning the HTML in the result.#{1}":[440,454],"#Attach Hooks":[455,541],"#Attach Hooks#{1}":[456,541],"#4) Run the crawler on an example page":[542,722],"#4) Run the crawler on an example page#{1}":[543,613],"#4) Run the crawler on an example page#{2}":[614,614],"#4) Run the crawler on an example page#{3}":[615,616],"#4) Run the crawler on an example page#{4}":[617,617],"#4) Run the crawler on an example page#{5}":[618,622],"#4) Run the crawler on an example page#{6}":[623,623],"#4) Run the crawler on an example page#{7}":[624,625],"#4) Run the crawler on an example page#{8}":[626