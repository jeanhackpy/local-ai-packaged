ces#Library Selection#{1}":[268,268],"#XLSX creation, editing, and analysis#Best Practices#Library Selection#{2}":[269,270],"#XLSX creation, editing, and analysis#Best Practices#Working with openpyxl":[271,277],"#XLSX creation, editing, and analysis#Best Practices#Working with openpyxl#{1}":[272,272],"#XLSX creation, editing, and analysis#Best Practices#Working with openpyxl#{2}":[273,273],"#XLSX creation, editing, and analysis#Best Practices#Working with openpyxl#{3}":[274,274],"#XLSX creation, editing, and analysis#Best Practices#Working with openpyxl#{4}":[275,275],"#XLSX creation, editing, and analysis#Best Practices#Working with openpyxl#{5}":[276,277],"#XLSX creation, editing, and analysis#Best Practices#Working with pandas":[278,282],"#XLSX creation, editing, and analysis#Best Practices#Working with pandas#{1}":[279,279],"#XLSX creation, editing, and analysis#Best Practices#Working with pandas#{2}":[280,280],"#XLSX creation, editing, and analysis#Best Practices#Working with pandas#{3}":[281,282],"#XLSX creation, editing, and analysis#Code Style Guidelines":[283,292],"#XLSX creation, editing, and analysis#Code Style Guidelines#{1}":[284,284],"#XLSX creation, editing, and analysis#Code Style Guidelines#{2}":[285,285],"#XLSX creation, editing, and analysis#Code Style Guidelines#{3}":[286,286],"#XLSX creation, editing, and analysis#Code Style Guidelines#{4}":[287,288],"#XLSX creation, editing, and analysis#Code Style Guidelines#{5}":[289,289],"#XLSX creation, editing, and analysis#Code Style Guidelines#{6}":[290,290],"#XLSX creation, editing, and analysis#Code Style Guidelines#{7}":[291,291],"#XLSX creation, editing, and analysis#Code Style Guidelines#{8}":[292,292]},"outlinks":[],"metadata":{"name":"xlsx","description":"Use this skill any time a spreadsheet file is the primary input or output. This means any task where the user wants to: open, read, edit, or fix an existing .xlsx, .xlsm, .csv, or .tsv file (e.g., adding columns, computing formulas, formatting, charting, cleaning messy data); create a new spreadsheet from scratch or from other data sources; or convert between tabular file formats. Trigger especially when the user references a spreadsheet file by name or path — even casually (like \"the xlsx in my downloads\") — and wants something done to it or produced from it. Also trigger for cleaning or restructuring messy tabular data files (malformed rows, misplaced headers, junk data) into proper spreadsheets. The deliverable must be a spreadsheet file. Do NOT trigger when the primary deliverable is a Word document, HTML report, standalone Python script, database pipeline, or Google Sheets API integration, even if tabular data is involved.","license":"Proprietary. LICENSE.txt has complete terms","tags":["#DIV/0","#VALUE","#N/A","#NAME"]},"task_lines":[232,233,234,237,238,239,240,241,242,245,246,247],"tasks":{"incomplete":{"all":[232,233,234,237,238,239,240,241,242,245,246,247],"top":[232,233,234,237,238,239,240,241,242,245,246,247]}},"codeblock_ranges":[[81,95],[104,116],[119,128],[138,140],[153,178],[182,205],[211,213],[216,218],[251,263]],"key":"00_System/Links/App_agent_skills_repo/skills_sh/anthropics-skills/xlsx/SKILL.md"},
