les for Professional UI#Icons & Visual Elements":[282,290],"#UI/UX Pro Max - Design Intelligence#Common Rules for Professional UI#Icons & Visual Elements#{1}":[284,290],"#UI/UX Pro Max - Design Intelligence#Common Rules for Professional UI#Interaction & Cursor":[291,298],"#UI/UX Pro Max - Design Intelligence#Common Rules for Professional UI#Interaction & Cursor#{1}":[293,298],"#UI/UX Pro Max - Design Intelligence#Common Rules for Professional UI#Light/Dark Mode Contrast":[299,307],"#UI/UX Pro Max - Design Intelligence#Common Rules for Professional UI#Light/Dark Mode Contrast#{1}":[301,307],"#UI/UX Pro Max - Design Intelligence#Common Rules for Professional UI#Layout & Spacing":[308,317],"#UI/UX Pro Max - Design Intelligence#Common Rules for Professional UI#Layout & Spacing#{1}":[310,317],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist":[318,352],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#{1}":[320,321],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Visual Quality":[322,328],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Visual Quality#{1}":[323,328],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Interaction":[329,334],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Interaction#{1}":[330,334],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Light/Dark Mode":[335,340],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Light/Dark Mode#{1}":[336,340],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Layout":[341,346],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Layout#{1}":[342,346],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Accessibility":[347,352],"#UI/UX Pro Max - Design Intelligence#Pre-Delivery Checklist#Accessibility#{1}":[348,352]},"outlinks":[],"metadata":{"name":"ui-ux-pro-max","description":"UI/UX design intelligence. 50 styles, 21 palettes, 50 font pairings, 20 charts, 9 stacks (React, Next.js, Vue, Svelte, SwiftUI, React Native, Flutter, Tailwind, shadcn/ui). Actions: plan, build, create, design, implement, review, fix, improve, optimize, enhance, refactor, check UI/UX code. Projects: website, landing page, dashboard, admin panel, e-commerce, SaaS, portfolio, blog, mobile app, .html, .tsx, .vue, .svelte. Elements: button, modal, navbar, sidebar, card, table, form, chart. Styles: glassmorphism, claymorphism, minimalism, brutalism, neumorphism, bento grid, dark mode, responsive, skeuomorphism, flat design. Topics: color palette, accessibility, animation, layout, typography, font pairing, spacing, hover, shadow, gradient. Integrations: shadcn/ui MCP for component search and examples."},"task_lines":[323,324,325,326,327,330,331,332,333,336,337,338,339,342,343,344,345,348,349,350,351],"tasks":{"incomplete":{"all":[323,324,325,326,327,330,331,332,333,336,337,338,339,342,343,344,345,348,349,350,351],"top":[323,324,325,326,327,330,331,332,333,336,337,338,339,342,343,344,345,348,349,350,351]}},"codeblock_ranges":[[98,100],[105,107],[110,112],[115,117],[137,139],[148,150],[156,158],[174,176],[227,229],[235,241],[245,247],[257,263]],"key":"00_System/Links/App_agent_skills_repo/ui-ux-pro-max/SKILL.md"},
