shared-values-not-value","line":51},{"title":"User Interface","target":"#9-user-interface","line":52},{"title":"Measuring View Dimensions","target":"#91-measuring-view-dimensions","line":53},{"title":"Modern React Native Styling Patterns","target":"#92-modern-react-native-styling-patterns","line":54},{"title":"Use contentInset for Dynamic ScrollView Spacing","target":"#93-use-contentinset-for-dynamic-scrollview-spacing","line":55},{"title":"Use contentInsetAdjustmentBehavior for Safe Areas","target":"#94-use-contentinsetadjustmentbehavior-for-safe-areas","line":56},{"title":"Use expo-image for Optimized Images","target":"#95-use-expo-image-for-optimized-images","line":57},{"title":"Use Galeria for Image Galleries and Lightbox","target":"#96-use-galeria-for-image-galleries-and-lightbox","line":58},{"title":"Use Native Menus for Dropdowns and Context Menus","target":"#97-use-native-menus-for-dropdowns-and-context-menus","line":59},{"title":"Use Native Modals Over JS-Based Bottom Sheets","target":"#98-use-native-modals-over-js-based-bottom-sheets","line":60},{"title":"Use Pressable Instead of Touchable Components","target":"#99-use-pressable-instead-of-touchable-components","line":61},{"title":"Design System","target":"#10-design-system","line":62},{"title":"Use Compound Components Over Polymorphic Children","target":"#101-use-compound-components-over-polymorphic-children","line":63},{"title":"Monorepo","target":"#11-monorepo","line":64},{"title":"Install Native Dependencies in App Directory","target":"#111-install-native-dependencies-in-app-directory","line":65},{"title":"Use Single Dependency Versions Across Monorepo","target":"#112-use-single-dependency-versions-across-monorepo","line":66},{"title":"Third-Party Dependencies","target":"#12-third-party-dependencies","line":67},{"title":"Import from Design System Folder","target":"#121-import-from-design-system-folder","line":68},{"title":"JavaScript","target":"#13-javascript","line":69},{"title":"Hoist Intl Formatter Creation","target":"#131-hoist-intl-formatter-creation","line":70},{"title":"Fonts","target":"#14-fonts","line":71},{"title":"Load fonts natively at build time","target":"#141-load-fonts-natively-at-build-time","line":72},{"title":"eslint-plugin-react","target":"https://github.com/jsx-eslint/eslint-plugin-react/blob/master/docs/rules/jsx-no-leaked-render.md","line":154},{"title":"https://example.com","target":"https://example.com","line":335},{"title":"LegendList getItemType","target":"https://legendapp.com/open-source/list/api/props/#getitemtype-v2","line":761},{"title":"Reanimated useDerivedValue","target":"https://docs.swmansion.com/react-native-reanimated/docs/core/useDerivedValue","line":937},{"title":"Gesture Handler Tap Gesture","target":"https://docs.swmansion.com/react-native-gesture-handler/docs/gestures/tap-gesture","line":989},{"title":"React Navigation Native Stack","target":"https://reactnavigation.org/docs/native-stack-navigator","line":1187},{"title":"React Native Bottom Tabs with React Navigation","target":"https://oss.callstack.com/react-native-bottom-tabs/docs/guides/usage-with-react-navigation","line":1189},{"title":"React Native Bottom Tabs with Expo Router","target":"https://oss.callstack.com/react-native-bottom-tabs/docs/guides/usage-with-expo-router","line":1191},{"title":"Expo Router Native Tabs","target":"https://docs.expo.dev/router/advanced/native-tabs","line":1193},{"title":"https://react.dev/learn/choosing-the-state-structure","target":"https://react.dev/learn/choosing-the-state-structure","line":1426},{"title":"Reanimated docs","target":"https://docs.swmansion.com/react-native-reanimated/docs/core/useSharedValue/#react-compiler-support","line":1770},{"title":"or[Q6.' }}\n  contentFit=\"cover\"\n  transition={200}\n  style={styles.image}\n/>\n```\n\n**With priority and caching:**\n\n```tsx\n<Image\n  source={{ uri: url }}\n  priority=\"high\"\n  cachePolicy=\"memory-disk\"\n  style={styles.hero}\n/>\n```\n\n**Key props:**\n\n- `placeholder` — Blurhash or thumbnail while loading\n\n- `contentFit` — `cover`, `contain`, `fill`, `scale-down`\n\n- `transition` — Fade-in duration (ms)\n\n- `priority` — `low`, `normal`, `high`\n\n- `cachePolicy` — `memory`, `disk`, `memory-disk`, `none`\n\n- `recyclingKey` — Unique key for list recycling\n\nFor cross-platform (web + native), use `SolitoImage` from `solito/image` which uses `expo-image` under the hood.\n\nReference: [https://docs.expo.dev/versions/latest/sdk/image/","target":"https://docs.expo.dev/versions/latest/sdk/image/","line":2073},{"title":"https://github.com/nandorojo/galeria","target":"https://github.com/nandorojo/galeria","line":2209},{"title":"zeego","target":"https://zeego.dev","line":2219},{"title":"https://zeego.dev/components/dropdown-menu","target":"https://zeego.dev/components/dropdown-menu","line":2381},{"title":"Expo Font Documentation","target":"https://docs.expo.dev/versions/latest/sdk/font/","line":2842},{"title":"https://react.dev","target":"https://react.dev","line":2890},{"title":"https://reactnative.dev","target":"https://reactnative.dev","line":2891},{"title":"https://docs.swmansion.com/react-native-reanimated","target":"https://docs.swmansion.com/react-native-reanimated","line":2892},{"title":"https://docs.swmansion.com/react-native-gesture-handler","target":"https://docs.swmansion.com/react-native-gesture-handler","line":2893},{"title":"https://docs.expo.dev","target":"https://docs.expo.dev","line":2894},{"title":"https://legendapp.com/open-source/legend-list","target":"https://legendapp.com/open-source/legend-list","line":2895},{"title":"https://github.com/nandorojo/galeria","target":"https://github.com/nandorojo/galeria","line":2896},{"title":"https://zeego.dev","target":"https://zeego.dev","line":2897}],"class_name":"SmartBlock"},
