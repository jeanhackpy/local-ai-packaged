b/master/docs/rules/jsx-no-leaked-render.md","line":154},{"title":"https://example.com","target":"https://example.com","line":335},{"title":"LegendList getItemType","target":"https://legendapp.com/open-source/list/api/props/#getitemtype-v2","line":761},{"title":"Reanimated useDerivedValue","target":"https://docs.swmansion.com/react-native-reanimated/docs/core/useDerivedValue","line":937},{"title":"Gesture Handler Tap Gesture","target":"https://docs.swmansion.com/react-native-gesture-handler/docs/gestures/tap-gesture","line":989},{"title":"React Navigation Native Stack","target":"https://reactnavigation.org/docs/native-stack-navigator","line":1187},{"title":"React Native Bottom Tabs with React Navigation","target":"https://oss.callstack.com/react-native-bottom-tabs/docs/guides/usage-with-react-navigation","line":1189},{"title":"React Native Bottom Tabs with Expo Router","target":"https://oss.callstack.com/react-native-bottom-tabs/docs/guides/usage-with-expo-router","line":1191},{"title":"Expo Router Native Tabs","target":"https://docs.expo.dev/router/advanced/native-tabs","line":1193},{"title":"https://react.dev/learn/choosing-the-state-structure","target":"https://react.dev/learn/choosing-the-state-structure","line":1426},{"title":"Reanimated docs","target":"https://docs.swmansion.com/react-native-reanimated/docs/core/useSharedValue/#react-compiler-support","line":1770},{"title":"or[Q6.' }}\n  contentFit=\"cover\"\n  transition={200}\n  style={styles.image}\n/>\n```\n\n**With priority and caching:**\n\n```tsx\n<Image\n  source={{ uri: url }}\n  priority=\"high\"\n  cachePolicy=\"memory-disk\"\n  style={styles.hero}\n/>\n```\n\n**Key props:**\n\n- `placeholder` — Blurhash or thumbnail while loading\n\n- `contentFit` — `cover`, `contain`, `fill`, `scale-down`\n\n- `transition` — Fade-in duration (ms)\n\n- `priority` — `low`, `normal`, `high`\n\n- `cachePolicy` — `memory`, `disk`, `memory-disk`, `none`\n\n- `recyclingKey` — Unique key for list recycling\n\nFor cross-platform (web + native), use `SolitoImage` from `solito/image` which uses `expo-image` under the hood.\n\nReference: [https://docs.expo.dev/versions/latest/sdk/image/","target":"https://docs.expo.dev/versions/latest/sdk/image/","line":2073},{"title":"https://github.com/nandorojo/galeria","target":"https://github.com/nandorojo/galeria","line":2209},{"title":"zeego","target":"https://zeego.dev","line":2219},{"title":"https://zeego.dev/components/dropdown-menu","target":"https://zeego.dev/components/dropdown-menu","line":2381},{"title":"Expo Font Documentation","target":"https://docs.expo.dev/versions/latest/sdk/font/","line":2842},{"title":"https://react.dev","target":"https://react.dev","line":2890},{"title":"https://reactnative.dev","target":"https://reactnative.dev","line":2891},{"title":"https://docs.swmansion.com/react-native-reanimated","target":"https://docs.swmansion.com/react-native-reanimated","line":2892},{"title":"https://docs.swmansion.com/react-native-gesture-handler","target":"https://docs.swmansion.com/react-native-gesture-handler","line":2893},{"title":"https://docs.expo.dev","target":"https://docs.expo.dev","line":2894},{"title":"https://legendapp.com/open-source/legend-list","target":"https://legendapp.com/open-source/legend-list","line":2895},{"title":"https://github.com/nandorojo/galeria","target":"https://github.com/nandorojo/galeria","line":2896},{"title":"https://zeego.dev","target":"https://zeego.dev","line":2897}],"task_lines":[],"tasks":{},"codeblock_ranges":[[95,105],[109,118],[122,131],[135,146],[168,175],[179,189],[212,226],[230,238],[242,254],[258,272],[276,287],[309,319],[323,333],[349,365],[369,380],[384,398],[402,416],[450,472],[476,497],[501,507],[519,524],[560,570],[576,594],[598,604],[608,621],[643,654],[658,673],[677,690],[708,721],[725,741],[765,787],[791,817],[821,843],[872,883],[887,904],[908,921],[941,957],[961,971],[993,1020],[1024,1064],[1092,1109],[1113,1137],[1141,1158],[1197,1210],[1214,1227],[1231,1238],[1242,1255],[1259,1