y","target":"scripts/dataset_inspector.py","line":570},{"title":"scripts/estimate_cost.py","target":"scripts/estimate_cost.py","line":571},{"title":"references/object_detection_training_notebook.md","target":"references/object_detection_training_notebook.md","line":572},{"title":"references/image_classification_training_notebook.md","target":"references/image_classification_training_notebook.md","line":573},{"title":"references/finetune_sam2_trainer.md","target":"references/finetune_sam2_trainer.md","line":574},{"title":"references/timm_trainer.md","target":"references/timm_trainer.md","line":575},{"title":"references/hub_saving.md","target":"references/hub_saving.md","line":576},{"title":"references/reliability_principles.md","target":"references/reliability_principles.md","line":577},{"title":"Transformers Object Detection Guide","target":"https://huggingface.co/docs/transformers/tasks/object_detection","line":581},{"title":"Transformers Image Classification Guide","target":"https://huggingface.co/docs/transformers/tasks/image_classification","line":582},{"title":"DETR Model Documentation","target":"https://huggingface.co/docs/transformers/model_doc/detr","line":583},{"title":"ViT Model Documentation","target":"https://huggingface.co/docs/transformers/model_doc/vit","line":584},{"title":"HF Jobs Guide","target":"https://huggingface.co/docs/huggingface_hub/guides/jobs","line":585},{"title":"HF Jobs Configuration","target":"https://huggingface.co/docs/hub/en/jobs-configuration","line":586},{"title":"HF Jobs CLI Reference","target":"https://huggingface.co/docs/huggingface_hub/guides/cli#hf-jobs","line":587},{"title":"Object Detection Models","target":"https://huggingface.co/models?pipeline_tag=object-detection","line":588},{"title":"Image Classification Models","target":"https://huggingface.co/models?pipeline_tag=image-classification","line":589},{"title":"SAM2 Model Documentation","target":"https://huggingface.co/docs/transformers/model_doc/sam2","line":590},{"title":"SAM Model Documentation","target":"https://huggingface.co/docs/transformers/model_doc/sam","line":591},{"title":"Object Detection Datasets","target":"https://huggingface.co/datasets?task_categories=task_categories:object-detection","line":592},{"title":"Image Classification Datasets","target":"https://huggingface.co/datasets?task_categories=task_categories:image-classification","line":593}],"metadata":{"name":"huggingface-vision-trainer","description":"Trains and fine-tunes vision models for object detection (D-FINE, RT-DETR v2, DETR, YOLOS), image classification (timm models — MobileNetV3, MobileViT, ResNet, ViT/DINOv3 — plus any Transformers classifier), and SAM/SAM2 segmentation using Hugging Face Transformers on Hugging Face Jobs cloud GPUs. Covers COCO-format dataset preparation, Albumentations augmentation, mAP/mAR evaluation, accuracy metrics, SAM segmentation with bbox/point prompts, DiceCE loss, hardware selection, cost estimation, Trackio monitoring, and Hub persistence. Use when users mention training object detection, image classification, SAM, SAM2, segmentation, image matting, DETR, D-FINE, RT-DETR, ViT, timm, MobileNet, ResNet, bounding box models, or fine-tuning vision models on Hugging Face Jobs."},"task_lines":[],"tasks":{},"codeblock_ranges":[[30,33],[84,89],[92,94],[97,106],[121,128],[142,176],[197,199],[203,215],[235,240],[252,255],[266,275],[279,287],[291,298],[369,391],[393,405],[420,441],[443,455],[471,491],[493,505],[525,529],[532,538]],"key":"00_System/Links/Gemini_Extensions/huggingface-skills/skills/huggingface-vision-trainer/SKILL.md"},
