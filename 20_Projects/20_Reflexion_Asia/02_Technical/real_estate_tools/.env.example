# Real Estate Tools - Configuration Template
# Copy to .env and fill in your values

# ========== DATABASE (PostgreSQL) ==========
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_postgresql_password

# ========== SUPABASE ==========
SUPABASE_URL=your_supabase_project_url
ANON_KEY=your_supabase_anon_key
SERVICE_ROLE_KEY=your_service_role_key

# ========== CLAUDE API ==========
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# ========== FLASK API ==========
FLASK_PORT=5001
FLASK_ENV=development
FLASK_DEBUG=false

# ========== SSH TUNNEL ==========
# For developers tunneling into the VPS
SSH_HOST=31.97.67.145
SSH_USER=phil
SSH_PORT=22
SSH_TUNNEL_LOCAL_PORT=3000
SSH_TUNNEL_REMOTE_PORT=8000

# ========== OPTIONAL: LOGGING ==========
LOG_LEVEL=INFO
LOG_FILE=app.log
