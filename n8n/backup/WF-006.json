{
  "name": "WF-006-MONITOR-HEALTH-ALL",
  "nodes": [
    {
      "id": "h1",
      "name": "Daily 07:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
